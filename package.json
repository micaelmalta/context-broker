{
    "name": "context-broker",
    "version": "1.0.0",
    "description": "Lazy-loading MCP broker for Claude Code",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "context-broker": "./dist/index.js"
    },
    "files": [
        "dist",
        "config"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/micaelmalta/context-broker.git"
    },
    "homepage": "https://github.com/micaelmalta/context-broker",
    "bugs": {
        "url": "https://github.com/micaelmalta/context-broker/issues"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.js",
        "migrate": "node scripts/migrate.mjs",
        "revert-migration": "node scripts/revert-migration.mjs",
        "benchmark": "node scripts/benchmark.mjs",
        "prepublishOnly": "npm run build",
        "test": "node --experimental-vm-modules --no-warnings=ExperimentalWarning node_modules/.bin/jest"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/node": "^20.0.0",
        "jest": "^30.4.2",
        "ts-jest": "^29.4.9",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    }
}
